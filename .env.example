# Copy this file to .env and fill in real values as you get each credential.
# Everything below is safe to leave blank — the app runs in mock mode until filled in.
#
# IMPORTANT: this is a standalone project with its OWN Supabase project, Vercel
# project, Slack app, and PostHog Personal API Key — do not paste in credentials
# copied from the Content Tracking Dashboard's .env. The one deliberate exception
# is POSTHOG_PROJECT_ID: that's the same underlying HydraDB PostHog project (there's
# only one real signups data source), just read here with a brand-new API key.

DATABASE_URL="postgresql://USER@localhost:5432/weekly_gtm_tracker?schema=public"
DIRECT_URL="postgresql://USER@localhost:5432/weekly_gtm_tracker?schema=public"

# Protects the /api/cron/* endpoints once deployed — any random string works.
CRON_SECRET=""

# Public URL of the deployed tracker, used in the "copy as Discord text" link.
APP_URL=""

# --- Slack (new app, separate from the Content Tracking Dashboard's bot) ---
# Used ONLY for reading the CommunityMentions agency's daily CSV drop — this
# project never posts to Slack (no weekly-report distribution). Bot Token
# Scopes needed: channels:history, channels:read (and groups:history instead
# of channels:history if the channel is private).
SLACK_BOT_TOKEN=""
# The existing/dedicated channel where the agency's daily report already lands.
# Leave blank to disable Slack-based mentions ingestion (the manual CSV upload
# page at /mentions/upload always works regardless).
SLACK_MENTIONS_CHANNEL_ID=""

# --- PostHog (same HydraDB project as the Content Tracking Dashboard, new key) ---
POSTHOG_API_KEY=""
POSTHOG_PROJECT_ID=""
POSTHOG_HOST="https://us.posthog.com"

# --- Google Search Console (Search Analytics API) ---
# Service account JSON, granted read access on the verified hydradb.com property
# in Search Console. GOOGLE_SEARCH_CONSOLE_PRIVATE_KEY should keep its \n escapes
# (paste the JSON key's "private_key" value as-is, in quotes).
GOOGLE_SEARCH_CONSOLE_CLIENT_EMAIL=""
GOOGLE_SEARCH_CONSOLE_PRIVATE_KEY=""
# The exact "Property" identifier as it appears in Search Console, e.g.
# "sc-domain:hydradb.com" for a domain property or "https://hydradb.com/" for a
# URL-prefix property.
GOOGLE_SEARCH_CONSOLE_SITE_URL=""

# --- Twitter/X scraper (Apify "apidojo/tweet-scraper" actor) ---
# Unlocks Twitter account health (follower count, weekly engagement, top tweet)
# and general Twitter mentions of HydraDB (feeds the brand_mentions log) — no
# Twitter login/cookie required, just an Apify account token.
# The handle to pull account health for is set on /settings (default Hydra_DB),
# and the mentions search reuses the Branded Query Terms list above.
APIFY_API_TOKEN=""

# --- Discord bot (total member count only — see /settings for the guild ID) ---
# New Discord application at discord.com/developers/applications -> Bot tab ->
# copy the token. No privileged intents needed for just the member count. Invite
# the bot to the server (OAuth2 URL Generator, "bot" scope, no permissions needed).
DISCORD_BOT_TOKEN=""
